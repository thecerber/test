# Copy to .env in repo root (optional; compose has defaults)

# PostgreSQL
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_PORT=5432

# Symfony
APP_SECRET=change_me_use_openssl_rand_hex_32

# Ports on host
BACKEND_PORT=8080
FRONTEND_DEV_PORT=5173
FRONTEND_PROD_PORT=3000

# Docker Compose project name (image tag prefix)
# COMPOSE_PROJECT_NAME=app
